# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://dealtrust.app

# ── Turso Database ─────────────────────────────────────────
# Get these from: https://turso.tech → your database → Connect
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Groq AI (free) ─────────────────────────────────────────
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Resend Email (free: 3000/mo) ───────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_key
RESEND_FROM=alerts@dealtrust.app

# ── Affiliate IDs ──────────────────────────────────────────
# Jumia KOL: https://kol.jumia.com
JUMIA_AFFILIATE_ID=your-jumia-kol-id

# Konga: https://www.konga.com/affiliate
KONGA_AFFILIATE_ID=your-konga-id

# Temu: https://www.temu.com/affiliate_recruit.html
TEMU_AFFILIATE_ID=your-temu-id

# ── Security ───────────────────────────────────────────────
# Random secret — run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COUPON_SECRET=replace-with-32-char-random-string
CRON_SECRET=replace-with-another-random-string
